# ==========================================
# Flask Backend Configuration
# ==========================================

# A secure random string for signing session cookies in production.
# This prevents sessions from resetting every time the server restarts.
# You can generate one with: python -c "import secrets; print(secrets.token_hex(24))"
FLASK_SECRET_KEY=paste_a_random_secure_string_here

# When deploying to Render/Production, you usually don't need this, 
# but for local testing without HTTPS, set it to 1.
# OAUTHLIB_INSECURE_TRANSPORT=1

# ==========================================
# Secret Files on Render (Not Env Vars)
# ==========================================
# Please note: On Render, instead of parsing large JSON strings via .env variables,
# you should use Render's "Secret Files" feature.
# In the Render dashboard under "Environment" -> "Secret Files":
#
# 1. Create a secret file named: firebase_credentials.json
#    Paste the contents of your local firebase_credentials.json file into it.
#
# 2. Create another secret file named: credentials.json
#    Paste the contents of your local Google OAuth credentials.json file into it.
#
# Doing this will securely mount those JSON files right into the server's root folder!
